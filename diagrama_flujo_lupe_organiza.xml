<mxfile host="app.diagrams.net">
  <diagram name="Flowchart Contratos Laborales">
    <mxGraphModel dx="1200" dy="1600" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>

        <!-- INICIO -->
        <mxCell id="start" value="Inicio" style="ellipse;fillColor=#d5e8d4;" vertex="1" parent="1">
          <mxGeometry x="500" y="40" width="120" height="60" as="geometry"/>
        </mxCell>

        <mxCell id="datos" value="Ingresar datos del trabajador&#xa;(nombre, cédula, correo)" style="rounded=1;" vertex="1" parent="1">
          <mxGeometry x="430" y="130" width="260" height="70" as="geometry"/>
        </mxCell>

        <mxCell id="decision" value="¿Qué desea hacer?" style="rhombus;fillColor=#fff2cc;" vertex="1" parent="1">
          <mxGeometry x="460" y="240" width="200" height="100" as="geometry"/>
        </mxCell>

        <!-- NUEVO CONTRATO -->
        <mxCell id="contrato" value="Seleccionar tipo de contrato&#xa;(fijo, indefinido, obra)" style="rounded=1;" vertex="1" parent="1">
          <mxGeometry x="150" y="400" width="260" height="70" as="geometry"/>
        </mxCell>

        <mxCell id="ia" value="IA genera cláusulas&#xa;(objeto, duración, terminación)" style="rounded=1;" vertex="1" parent="1">
          <mxGeometry x="150" y="500" width="260" height="70" as="geometry"/>
        </mxCell>

        <mxCell id="doc" value="Generar contrato no editable&#xa;(solo vista e impresión)" style="rounded=1;" vertex="1" parent="1">
          <mxGeometry x="150" y="600" width="260" height="70" as="geometry"/>
        </mxCell>

        <mxCell id="alerta" value="Registrar contrato y programar&#xa;alerta 35 días antes" style="rounded=1;" vertex="1" parent="1">
          <mxGeometry x="150" y="700" width="260" height="70" as="geometry"/>
        </mxCell>

        <mxCell id="preaviso" value="Enviar alerta y generar preaviso" style="rounded=1;" vertex="1" parent="1">
          <mxGeometry x="150" y="800" width="260" height="70" as="geometry"/>
        </mxCell>

        <!-- MODIFICACIÓN -->
        <mxCell id="mod" value="Actualizar datos&#xa;(salario, cargo, modalidad)" style="rounded=1;" vertex="1" parent="1">
          <mxGeometry x="450" y="400" width="260" height="70" as="geometry"/>
        </mxCell>

        <mxCell id="anexo" value="Generar documento anexo" style="rounded=1;" vertex="1" parent="1">
          <mxGeometry x="450" y="500" width="260" height="70" as="geometry"/>
        </mxCell>

        <!-- TERMINACIÓN -->
        <mxCell id="tipoTerm" value="¿Tipo de terminación?" style="rhombus;" vertex="1" parent="1">
          <mxGeometry x="780" y="400" width="220" height="100" as="geometry"/>
        </mxCell>

        <mxCell id="docTerm" value="Generar documento&#xa;(prueba / sin causa / obra)" style="rounded=1;" vertex="1" parent="1">
          <mxGeometry x="800" y="550" width="260" height="70" as="geometry"/>
        </mxCell>

        <mxCell id="examen" value="Notificar examen médico de retiro" style="rounded=1;" vertex="1" parent="1">
          <mxGeometry x="800" y="650" width="260" height="70" as="geometry"/>
        </mxCell>

        <!-- POLÍTICAS -->
        <mxCell id="politica" value="Seleccionar política o reglamento" style="rounded=1;" vertex="1" parent="1">
          <mxGeometry x="450" y="650" width="260" height="70" as="geometry"/>
        </mxCell>

        <mxCell id="validar" value="¿Datos completos?" style="rhombus;" vertex="1" parent="1">
          <mxGeometry x="470" y="760" width="200" height="100" as="geometry"/>
        </mxCell>

        <mxCell id="emitir" value="Emitir documento" style="rounded=1;" vertex="1" parent="1">
          <mxGeometry x="450" y="900" width="260" height="70" as="geometry"/>
        </mxCell>

        <!-- FIN -->
        <mxCell id="fin" value="Fin" style="ellipse;fillColor=#f8cecc;" vertex="1" parent="1">
          <mxGeometry x="500" y="1050" width="120" height="60" as="geometry"/>
        </mxCell>

        <!-- CONEXIONES -->
        <mxCell edge="1" parent="1" source="start" target="datos"/>
        <mxCell edge="1" parent="1" source="datos" target="decision"/>

        <!-- ramas -->
        <mxCell edge="1" parent="1" source="decision" target="contrato" value="Nuevo contrato"/>
        <mxCell edge="1" parent="1" source="decision" target="mod" value="Modificar"/>
        <mxCell edge="1" parent="1" source="decision" target="tipoTerm" value="Terminar"/>
        <mxCell edge="1" parent="1" source="decision" target="politica" value="Políticas"/>

        <!-- contrato -->
        <mxCell edge="1" parent="1" source="contrato" target="ia"/>
        <mxCell edge="1" parent="1" source="ia" target="doc"/>
        <mxCell edge="1" parent="1" source="doc" target="alerta"/>
        <mxCell edge="1" parent="1" source="alerta" target="preaviso"/>
        <mxCell edge="1" parent="1" source="preaviso" target="fin"/>

        <!-- modificación -->
        <mxCell edge="1" parent="1" source="mod" target="anexo"/>
        <mxCell edge="1" parent="1" source="anexo" target="fin"/>

        <!-- terminación -->
        <mxCell edge="1" parent="1" source="tipoTerm" target="docTerm"/>
        <mxCell edge="1" parent="1" source="docTerm" target="examen"/>
        <mxCell edge="1" parent="1" source="examen" target="fin"/>

        <!-- políticas -->
        <mxCell edge="1" parent="1" source="politica" target="validar"/>
        <mxCell edge="1" parent="1" source="validar" target="emitir" value="Sí"/>
        <mxCell edge="1" parent="1" source="validar" target="politica" value="No"/>
        <mxCell edge="1" parent="1" source="emitir" target="fin"/>

      </root>
    </mxGraphModel>
  </diagram>
</mxfile>